# This .dockerignore file is used to specify files and directories that should be excluded from the Docker build context. This helps to reduce the size of the build context and improve build performance.

# ============================================================
# Node.js
# ============================================================
**/node_modules
**/.npm
**/npm-debug.log

# ============================================================
# Build Output
# ============================================================
**/dist
**/build
**/.next
**/.nuxt

# ============================================================
# Git
# ============================================================
.git
.gitignore
.gitattributes

# ============================================================
# Environment Files
# ============================================================
**/.env
**/.env.local
**/.env.development
**/.env.test

# ============================================================
# IDE
# ============================================================
.vscode
.idea
*.swp
*.swo
**/.DS_Store
**/Thumbs.db

# ============================================================
# Testing
# ============================================================
**/coverage
**/__tests__
**/*.test.js
**/*.spec.js

# ============================================================
# Logs
# ============================================================
**/logs
**/*.log

# ============================================================
# Temporary Files
# ============================================================
**/tmp
**/temp

# ============================================================
# Kubernetes / Monitoring
# ============================================================
k8s/
monitoring/
reports/

# ============================================================
# Jenkins (optional)
# ============================================================
jenkins/

# ============================================================
# Keep Docker files
# ============================================================
!docker/**